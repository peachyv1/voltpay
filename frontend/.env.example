# Stellar Issuer Account
STELLAR_ISSUER_SECRET=S...
STELLAR_ISSUER_PUBLIC=G...

# Stellar Distributor Account
STELLAR_DISTRIBUTOR_SECRET=S...
STELLAR_DISTRIBUTOR_PUBLIC=G...

# Soroban Contract Addresses (filled after deploy)
POOL_CONTRACT_ADDRESS=C...
TOKEN_CONTRACT_ADDRESS=C...
BRIDGE_CONTRACT_ADDRESS=C...

# Soroban RPC
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon
HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# VOLT Asset issuer — needed client-side for trustline transaction
NEXT_PUBLIC_VOLT_ISSUER=G...

# Sentry (optional — leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
